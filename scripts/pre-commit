#!/bin/sh
# Gaze Pre-commit Hook

echo "Checking formatting..."
just fmt-check
if [ $? -ne 0 ]; then
    echo "Error: Formatting check failed. Run 'just fmt' to fix."
    exit 1
fi

echo "Running clippy..."
just lint
if [ $? -ne 0 ]; then
    echo "Error: Clippy check failed."
    exit 1
fi

echo "Pre-commit checks passed!"
exit 0
